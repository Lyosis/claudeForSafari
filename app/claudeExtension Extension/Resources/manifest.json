{
  "manifest_version": 2,
  "name": "Claude for Safari",
  "version": "1.2.0",
  "description": "Allows Claude to read and control Safari pages",

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Claude for Safari"
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "14.0"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "http://localhost/*",
    "https://localhost/*",
    "<all_urls>"
  ]
}
